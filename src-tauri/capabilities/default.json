{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main android",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*.*"
        },
        {
          "url": "http://*.*"
        }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "secure-storage:allow-delete",
    "secure-storage:allow-get",
    "secure-storage:allow-set",
    "secure-storage:default"
  ]
}
